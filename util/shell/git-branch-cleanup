#!/usr/bin/env bash
# git-branch-cleanup - Clean up branches merged into the current (or specified) ref
# Provides a concise summary instead of noisy git error output

set -euo pipefail

ref=${1:-$(git branch --show-current)}

# Collect worktree branches for fast lookup
declare -A worktree_branches
while IFS= read -r line; do
    if [[ "$line" =~ ^branch\ refs/heads/(.+)$ ]]; then
        worktree_branches["${BASH_REMATCH[1]}"]=1
    fi
done < <(git worktree list --porcelain)

# Collect merged branches, excluding the ref itself
merged=()
while IFS= read -r branch; do
    [ -z "$branch" ] && continue
    [ "$branch" = "$ref" ] && continue
    merged+=("$branch")
done < <(git branch --merged "$ref" --format='%(refname:short)')

if [ ${#merged[@]} -eq 0 ]; then
    echo "No merged branches to clean up."
    exit 0
fi

deleted=()
skipped_worktree=()
skipped_unmerged=()

for branch in "${merged[@]}"; do
    # Skip branches used by worktrees
    if [[ -n "${worktree_branches[$branch]+x}" ]]; then
        skipped_worktree+=("$branch")
        continue
    fi

    # Try to delete; capture stderr for not-fully-merged cases
    if err=$(git branch -d "$branch" 2>&1); then
        deleted+=("$branch")
    else
        if [[ "$err" == *"not fully merged"* ]]; then
            skipped_unmerged+=("$branch")
        else
            # Unexpected error — show it
            echo "  error deleting '$branch': $err"
        fi
    fi
done

# Summary
plural() { [ "$1" -eq 1 ] && echo "branch" || echo "branches"; }

if [ ${#deleted[@]} -gt 0 ]; then
    echo "Deleted ${#deleted[@]} $(plural ${#deleted[@]}):"
    printf '  %s\n' "${deleted[@]}"
fi

if [ ${#skipped_worktree[@]} -gt 0 ]; then
    echo "Skipped ${#skipped_worktree[@]} $(plural ${#skipped_worktree[@]}) (in use by worktree):"
    printf '  %s\n' "${skipped_worktree[@]}"
fi

if [ ${#skipped_unmerged[@]} -gt 0 ]; then
    echo "Skipped ${#skipped_unmerged[@]} $(plural ${#skipped_unmerged[@]}) (not fully merged to remote):"
    printf '  %s\n' "${skipped_unmerged[@]}"
fi

if [ ${#deleted[@]} -eq 0 ] && [ ${#skipped_worktree[@]} -eq 0 ] && [ ${#skipped_unmerged[@]} -eq 0 ]; then
    echo "No merged branches to clean up."
fi
