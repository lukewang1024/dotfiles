#!/bin/sh
# git-branch-cleanup - Clean up branches merged into the current (or specified) ref
# Provides a concise summary instead of noisy git error output

set -eu

ref=${1:-$(git branch --show-current)}

# Collect worktree branches for fast lookup (newline-delimited)
worktree_branches=$(git worktree list --porcelain | sed -n 's|^branch refs/heads/||p')

# Collect merged branches, excluding the ref itself
merged=$(git branch --merged "$ref" --format='%(refname:short)' | grep -v "^${ref}$" || true)

if [ -z "$merged" ]; then
    echo "No merged branches to clean up."
    exit 0
fi

deleted=""
skipped_worktree=""
skipped_unmerged=""
n_deleted=0
n_skipped_worktree=0
n_skipped_unmerged=0

for branch in $merged; do
    # Skip branches used by worktrees
    if echo "$worktree_branches" | grep -qx "$branch"; then
        skipped_worktree="${skipped_worktree}  ${branch}
"
        n_skipped_worktree=$((n_skipped_worktree + 1))
        continue
    fi

    # Try to delete; capture stderr for not-fully-merged cases
    if err=$(git branch -d "$branch" 2>&1); then
        deleted="${deleted}  ${branch}
"
        n_deleted=$((n_deleted + 1))
    else
        case "$err" in
            *"not fully merged"*)
                skipped_unmerged="${skipped_unmerged}  ${branch}
"
                n_skipped_unmerged=$((n_skipped_unmerged + 1))
                ;;
            *)
                echo "  error deleting '$branch': $err"
                ;;
        esac
    fi
done

# Summary
plural() { [ "$1" -eq 1 ] && echo "branch" || echo "branches"; }

if [ $n_deleted -gt 0 ]; then
    echo "Deleted $n_deleted $(plural $n_deleted):"
    printf '%s' "$deleted"
fi

if [ $n_skipped_worktree -gt 0 ]; then
    echo "Skipped $n_skipped_worktree $(plural $n_skipped_worktree) (in use by worktree):"
    printf '%s' "$skipped_worktree"
fi

if [ $n_skipped_unmerged -gt 0 ]; then
    echo "Skipped $n_skipped_unmerged $(plural $n_skipped_unmerged) (not fully merged to remote):"
    printf '%s' "$skipped_unmerged"
fi

if [ $n_deleted -eq 0 ] && [ $n_skipped_worktree -eq 0 ] && [ $n_skipped_unmerged -eq 0 ]; then
    echo "No merged branches to clean up."
fi
