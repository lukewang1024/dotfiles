#!/bin/sh
# gen-tmuxinator-configs — (re)generate machine-local tmuxinator named configs
# in ~/.config/tmuxinator/ from every git worktree under a code root.
#
# Generic (no repo names live here); the configs it writes are machine-local and
# untracked. Re-run it whenever the pool changes — it is idempotent and only
# touches files carrying its @generated marker, so hand-made configs are left
# alone.
#
# Gets a config: each repo's main checkout, plus numbered pool slots whose dir is
# named `<repo>-<number>` (e.g. axon-web-7). Skipped: use-and-throw worktrees
# under any `<repo>-worktrees/` dir (the ag-dev per-task convention), worktrees
# registered outside the code root, and non-numbered extra worktrees.
#
# Manual exclusions persist across re-runs via a one-name-per-line ignore file
# at ~/.config/tmuxinator/.genignore (blank lines and #comments allowed).
#
# Layout (tmux main-vertical, agent 55% via main-pane-width in tmux.conf):
#   Frontend (package.json / pnpm-workspace.yaml / frontend/):
#       agent(claude) | git(tig) / shell / dev / editor(nvim)     (4 right panes)
#   Backend:
#       agent(claude) | git(tig) / shell / editor(nvim)           (3 right panes)
# Pop the agent sidebar on demand with prefix+Tab.
#
# usage: gen-tmuxinator-configs [code_root]      (default: ~/Code)

set -eu
CODE_ROOT="${1:-$HOME/Code}"
CODE_ROOT=$(cd "$CODE_ROOT" 2>/dev/null && pwd -P || echo "$CODE_ROOT")  # canonical
DEST="${XDG_CONFIG_HOME:-$HOME/.config}/tmuxinator"
MARKER="# @generated by gen-tmuxinator-configs — do not edit; re-run to refresh"
mkdir -p "$DEST"

# Wipe our previously-generated files (keep hand-made ones); we rewrite the
# current set below, so vanished and now-excluded worktrees drop out cleanly.
for f in "$DEST"/*.yml; do
  [ -e "$f" ] || continue
  IFS= read -r first < "$f" || continue
  case "$first" in "$MARKER"*) rm -f "$f" ;; esac
done

# 1. Discover every worktree root. Scan a few depths to find at least one
#    checkout per repo, then let `git worktree list` expand to the full set
#    (catches deeply-nested worktrees the dir scan alone would miss).
seeds=$(cd "$CODE_ROOT" && for d in */ */*/ */*/*/; do
  [ -d "$d" ] || continue
  git -C "$d" rev-parse --show-toplevel 2>/dev/null || true
done | sort -u)

roots=$(for s in $seeds; do
  git -C "$s" worktree list --porcelain 2>/dev/null | sed -n 's/^worktree //p'
done | sort -u)

# Primary (main) worktree of each repo = the first entry git lists for it.
primaries=$(for s in $seeds; do
  git -C "$s" worktree list --porcelain 2>/dev/null | sed -n 's/^worktree //p' | head -1
done | sort -u)

# 2. Keep only the persistent pool: must live under CODE_ROOT (drops stray
#    worktrees registered in /tmp etc.), not under any `<repo>-worktrees/` dir
#    (the ag-dev use-and-throw convention), and not nested inside another root
#    (submodules, e.g. .../idl). A non-primary worktree is kept only if it is a
#    numbered slot `<repo>-<number>`.
roots=$(for r in $roots; do
  case "$r" in "$CODE_ROOT"/*) ;; *) continue ;; esac
  case "$r" in *-worktrees/*) continue ;; esac
  nested=0
  for p in $roots; do
    [ "$r" = "$p" ] && continue
    case "$r" in "$p"/*) nested=1; break ;; esac
  done
  [ "$nested" = 1 ] && continue
  is_primary=0
  for pm in $primaries; do [ "$r" = "$pm" ] && { is_primary=1; break; }; done
  if [ "$is_primary" = 0 ]; then
    base=$(basename "$r"); num=${base##*-}        # part after the last '-'
    case "$base" in "$num") continue ;; esac      # no '-' at all → not a slot
    case "$num" in ''|*[!0-9]*) continue ;; esac  # suffix not all digits → skip
  fi
  printf '%s\n' "$r"
done)

# 3. Write one named config per root (honoring .genignore manual exclusions).
IGNORE="$DEST/.genignore"
written=0 skipped=0
for r in $roots; do
  name=$(basename "$r" | tr ' .:/' '____')   # tmux-safe session name
  if [ -f "$IGNORE" ] && grep -qxF "$name" "$IGNORE" 2>/dev/null; then
    skipped=$((skipped + 1)); continue
  fi
  if [ -f "$r/package.json" ] || [ -f "$r/pnpm-workspace.yaml" ] || [ -f "$r/frontend/package.json" ]; then
    fe=1
  else
    fe=0
  fi
  {
    printf '%s (%s)\n' "$MARKER" "$r"
    printf 'name: %s\n' "$name"
    printf 'root: %s\n' "$r"
    printf 'startup_window: code\n'
    printf 'windows:\n'
    printf '  - code:\n'
    printf '      layout: main-vertical\n'
    printf '      panes:\n'
    printf '        - agent:\n            - claude\n'
    printf '        - git:\n            - tig\n'
    printf '        - shell:\n'
    [ "$fe" = 1 ] && printf '        - dev:\n            -\n'
    printf '        - editor:\n            - nvim\n'
  } > "$DEST/$name.yml"
  written=$((written + 1))
done
printf 'gen-tmuxinator-configs: wrote %s pool configs (%s ignored) → %s\n' "$written" "$skipped" "$DEST"
